<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MR G5 Pro Videos</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: #0f0f0f;
    color: white;
}

/* Header */
header {
    padding: 15px;
    text-align: center;
    background: #1f1f1f;
    font-size: 22px;
    font-weight: bold;
}

/* Search */
.search-box {
    padding: 10px;
    text-align: center;
}

.search-box input {
    width: 90%;
    padding: 10px;
    border-radius: 10px;
    border: none;
    outline: none;
}

/* Grid */
.container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 15px;
    padding: 15px;
}

/* Card */
.card {
    background: #1c1c1c;
    border-radius: 15px;
    overflow: hidden;
    transition: 0.3s;
}

.card:hover {
    transform: scale(1.05);
}

/* Video */
iframe {
    width: 100%;
    height: 200px;
}

/* Title */
.title {
    padding: 10px;
}

/* Buttons */
.actions {
    display: flex;
    justify-content: space-around;
    padding: 10px;
}

button {
    background: red;
    border: none;
    color: white;
    padding: 8px;
    border-radius: 8px;
    cursor: pointer;
}

/* Shorts style */
.short {
    height: 400px;
}
</style>
</head>

<body>

<header>🔥 MR G5 PRO TECH 🔥</header>

<div class="search-box">
<input type="text" id="search" placeholder="Search videos...">
</div>

<div class="container" id="videos">

<!-- VIDEO 1 -->
<div class="card">
<iframe src="https://www.youtube.com/embed/L4Lkt2r8GSw"></iframe>
<div class="title">Tech Tutorial 1</div>
<div class="actions">
<button onclick="like(this)">❤️ Like</button>
<button onclick="share()">📤 Share</button>
</div>
</div>

<!-- VIDEO 2 -->
<div class="card">
<iframe src="https://www.youtube.com/embed/wtV7uEJUpHY"></iframe>
<div class="title">Tech Tutorial 2</div>
<div class="actions">
<button onclick="like(this)">❤️ Like</button>
<button onclick="share()">📤 Share</button>
</div>
</div>

<!-- SHORTS -->
<div class="card">
<iframe class="short" src="https://www.youtube.com/embed/1vfA8E-rBFk"></iframe>
<div class="title">Short 1</div>
<div class="actions">
<button onclick="like(this)">❤️ Like</button>
</div>
</div>

<div class="card">
<iframe class="short" src="https://www.youtube.com/embed/CwQaO_IH7ys"></iframe>
<div class="title">Short 2</div>
<div class="actions">
<button onclick="like(this)">❤️ Like</button>
</div>
</div>

<div class="card">
<iframe class="short" src="https://www.youtube.com/embed/8uVegLQRcMc"></iframe>
<div class="title">Short 3</div>
<div class="actions">
<button onclick="like(this)">❤️ Like</button>
</div>
</div>

<div class="card">
<iframe class="short" src="https://www.youtube.com/embed/dHHS-0survU"></iframe>
<div class="title">Short 4</div>
<div class="actions">
<button onclick="like(this)">❤️ Like</button>
</div>
</div>

<div class="card">
<iframe class="short" src="https://www.youtube.com/embed/8h41q6Zy-0s"></iframe>
<div class="title">Short 5</div>
<div class="actions">
<button onclick="like(this)">❤️ Like</button>
</div>
</div>

</div>

<script>
// LIKE BUTTON
function like(btn) {
    btn.innerHTML = "❤️ Liked";
}

// SHARE BUTTON
function share() {
    alert("Share this video with friends!");
}

// SEARCH FUNCTION
document.getElementById("search").addEventListener("keyup", function() {
    let value = this.value.toLowerCase();
    let cards = document.querySelectorAll(".card");

    cards.forEach(card => {
        let title = card.innerText.toLowerCase();
        card.style.display = title.includes(value) ? "block" : "none";
    });
});
</script>

</body>
</html>
